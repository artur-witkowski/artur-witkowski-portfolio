---
import type { Lang } from '@/i18n/index';
import { t } from '@/i18n/index';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section id="hero" class="min-h-screen lg:min-h-[60vh] flex items-center justify-center relative px-6 overflow-hidden">
  <!-- Squares canvas background -->
  <canvas id="squares-bg" class="squares-canvas" aria-hidden="true"></canvas>

  <!-- Gradient orbs -->
  <div class="orb orb-1" aria-hidden="true"></div>
  <div class="orb orb-2" aria-hidden="true"></div>

  <div class="max-w-4xl mx-auto w-full relative z-10">
    <p class="hero-animate text-text-muted font-body text-lg md:text-xl mb-3" style="animation-delay: 0ms">
      {t('hero.greeting', lang)}
    </p>
    <h1 class="hero-animate font-heading font-bold text-5xl md:text-6xl lg:text-7xl gradient-text mb-5 leading-tight" style="animation-delay: 150ms">
      {t('hero.name', lang)}
    </h1>
    <p class="hero-animate font-body text-text-muted text-lg md:text-xl max-w-lg mb-10 leading-relaxed" style="animation-delay: 300ms">
      {t('hero.tagline', lang)}
    </p>

    <!-- Social links -->
    <div class="hero-animate flex items-center gap-3" style="animation-delay: 500ms">
      <a
        href="https://github.com/artur-witkowski"
        target="_blank"
        rel="noopener noreferrer"
        class="social-icon p-3 rounded-xl border border-border bg-surface/50 text-text-muted hover:text-accent hover:border-primary cursor-pointer"
        aria-label="GitHub"
      >
        <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
          <path d="M9 18c-4.51 2-5-2-7-2" />
        </svg>
      </a>
      <a
        href="https://linkedin.com/in/artur-witkowski"
        target="_blank"
        rel="noopener noreferrer"
        class="social-icon p-3 rounded-xl border border-border bg-surface/50 text-text-muted hover:text-accent hover:border-primary cursor-pointer"
        aria-label="LinkedIn"
      >
        <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
          <rect width="4" height="12" x="2" y="9" />
          <circle cx="4" cy="4" r="2" />
        </svg>
      </a>
      <a
        href="mailto:contact@arturwitkowski.com"
        class="social-icon p-3 rounded-xl border border-border bg-surface/50 text-text-muted hover:text-accent hover:border-primary cursor-pointer"
        aria-label="Email"
      >
        <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect width="20" height="16" x="2" y="4" rx="2" />
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
        </svg>
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 hero-animate" style="animation-delay: 800ms">
    <div class="scroll-indicator">
      <svg class="w-5 h-5 text-text-muted" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m6 9 6 6 6-6" />
      </svg>
    </div>
  </div>
</section>

<script is:inline>
(function () {
  var canvas = document.getElementById('squares-bg');
  if (!canvas) return;
  var ctx = canvas.getContext('2d');

  var squareSize = 40;
  var gridOffset = { x: 0, y: 0 };
  var hoveredSquare = null;
  var reqId = null;

  // Detect theme
  function isDark() {
    return document.documentElement.classList.contains('dark') || !document.documentElement.classList.contains('light');
  }

  function resizeCanvas() {
    canvas.width = canvas.offsetWidth;
    canvas.height = canvas.offsetHeight;
  }

  function drawGrid() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    var dark = isDark();
    var borderColor = dark ? 'rgba(30, 58, 95, 0.4)' : 'rgba(0, 0, 0, 0.06)';
    var hoverColor = dark ? 'rgba(8, 145, 178, 0.08)' : 'rgba(8, 145, 178, 0.06)';

    var startX = Math.floor(gridOffset.x / squareSize) * squareSize;
    var startY = Math.floor(gridOffset.y / squareSize) * squareSize;

    for (var x = startX; x < canvas.width + squareSize; x += squareSize) {
      for (var y = startY; y < canvas.height + squareSize; y += squareSize) {
        var squareX = x - (gridOffset.x % squareSize);
        var squareY = y - (gridOffset.y % squareSize);

        if (
          hoveredSquare &&
          Math.floor((x - startX) / squareSize) === hoveredSquare.x &&
          Math.floor((y - startY) / squareSize) === hoveredSquare.y
        ) {
          ctx.fillStyle = hoverColor;
          ctx.fillRect(squareX, squareY, squareSize, squareSize);
        }

        ctx.strokeStyle = borderColor;
        ctx.lineWidth = 0.5;
        ctx.strokeRect(squareX, squareY, squareSize, squareSize);
      }
    }

    // Radial vignette
    var grd = ctx.createRadialGradient(
      canvas.width / 2, canvas.height / 2, 0,
      canvas.width / 2, canvas.height / 2,
      Math.sqrt(canvas.width * canvas.width + canvas.height * canvas.height) / 2
    );
    var bgColor = dark ? '#0a1628' : '#f8fafc';
    grd.addColorStop(0, 'rgba(0,0,0,0)');
    grd.addColorStop(1, bgColor);
    ctx.fillStyle = grd;
    ctx.fillRect(0, 0, canvas.width, canvas.height);
  }

  function update() {
    gridOffset.x = (gridOffset.x - 0.3 + squareSize) % squareSize;
    gridOffset.y = (gridOffset.y - 0.15 + squareSize) % squareSize;
    drawGrid();
    reqId = requestAnimationFrame(update);
  }

  function handleMouseMove(e) {
    var rect = canvas.getBoundingClientRect();
    var mouseX = e.clientX - rect.left;
    var mouseY = e.clientY - rect.top;
    var startX = Math.floor(gridOffset.x / squareSize) * squareSize;
    var startY = Math.floor(gridOffset.y / squareSize) * squareSize;
    var hx = Math.floor((mouseX + gridOffset.x - startX) / squareSize);
    var hy = Math.floor((mouseY + gridOffset.y - startY) / squareSize);
    if (!hoveredSquare || hoveredSquare.x !== hx || hoveredSquare.y !== hy) {
      hoveredSquare = { x: hx, y: hy };
    }
  }

  function handleMouseLeave() {
    hoveredSquare = null;
  }

  // Only enable hover on non-touch
  if (window.matchMedia('(hover: hover)').matches) {
    canvas.addEventListener('mousemove', handleMouseMove);
    canvas.addEventListener('mouseleave', handleMouseLeave);
  }

  window.addEventListener('resize', resizeCanvas);
  resizeCanvas();
  reqId = requestAnimationFrame(update);

  // Theme change observer
  var observer = new MutationObserver(function () { drawGrid(); });
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
})();
</script>
