---
import type { Lang } from '@/i18n/index';
import { t } from '@/i18n/index';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<footer class="border-t border-border py-6 px-6">
  <div class="max-w-4xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-2 text-sm text-text-muted font-body">
    <span>&copy; 2026 Artur Witkowski</span>
    <span class="flex items-center gap-1.5">
      {t('footer.built', lang)}
      <span class="inline-block w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></span>
    </span>
  </div>
</footer>
