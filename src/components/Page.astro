---
import Layout from '@/layouts/Layout.astro';
import Nav from '@/components/Nav.astro';
import type { Lang } from '@/i18n/index';
import { t } from '@/i18n/index';
import { projects } from '@/data/projects';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const nameChars = t('hero.name', lang).split('');
const aboutLabelChars = t('about.label', lang).split('');
const projectsLabelChars = t('projects.label', lang).split('');

interface TechItem { name: string; icon?: string; iconUrl?: string; color?: string }

function techIconSrc(tech: TechItem): string | undefined {
  if (tech.iconUrl) return tech.iconUrl;
  if (tech.icon) return `https://cdn.simpleicons.org/${tech.icon}/${(tech.color || '#a0c4e8').slice(1)}`;
  return undefined;
}

const frontendTechs: TechItem[] = [
  { name: 'React', icon: 'react', color: '#61DAFB' },
  { name: 'TypeScript', icon: 'typescript', color: '#3178C6' },
  { name: 'Next.js', icon: 'nextdotjs', color: '#c0c0c0' },
  { name: 'JavaScript', icon: 'javascript', color: '#F7DF1E' },
  { name: 'Tailwind CSS', icon: 'tailwindcss', color: '#06B6D4' },
  { name: 'React Native', icon: 'react', color: '#61DAFB' },
  { name: 'HTML', icon: 'html5', color: '#E34F26' },
  { name: 'CSS', icon: 'css', color: '#663399' },
  { name: 'SASS', icon: 'sass', color: '#CC6699' },
  { name: 'Material UI', icon: 'mui', color: '#007FFF' },
  { name: 'Redux', icon: 'redux', color: '#764ABC' },
  { name: 'Zustand', iconUrl: 'https://api.iconify.design/devicon-plain/zustand.svg?color=%23F56565', color: '#F56565' },
  { name: 'React Query', icon: 'reactquery', color: '#FF4154' },
  { name: 'React Hook Form', icon: 'reacthookform', color: '#EC5990' },
  { name: 'Framer Motion', icon: 'framer', color: '#0055FF' },
  { name: 'React Router', icon: 'reactrouter', color: '#CA4245' },
  { name: 'Axios', icon: 'axios', color: '#5A29E4' },
  { name: 'jQuery', icon: 'jquery', color: '#0769AD' },
  { name: 'Expo', icon: 'expo', color: '#c0c0c0' },
  { name: 'Highcharts', color: '#6699A1' },
  { name: 'Storybook', icon: 'storybook', color: '#FF4785' },
  { name: 'Astro', icon: 'astro', color: '#BC52EE' },
];

const backendTechs: TechItem[] = [
  { name: 'Node.js', icon: 'nodedotjs', color: '#5FA04E' },
  { name: 'Express.js', icon: 'express', color: '#c0c0c0' },
  { name: 'Fastify', icon: 'fastify', color: '#c0c0c0' },
  { name: 'PostgreSQL', icon: 'postgresql', color: '#4169E1' },
  { name: 'MongoDB', icon: 'mongodb', color: '#47A248' },
  { name: 'MySQL', icon: 'mysql', color: '#4479A1' },
  { name: 'Prisma', icon: 'prisma', color: '#5A67D8' },
  { name: 'Drizzle ORM', icon: 'drizzle', color: '#C5F74F' },
  { name: 'Zod', icon: 'zod', color: '#3E67B1' },
  { name: 'Socket.IO', icon: 'socketdotio', color: '#c0c0c0' },
  { name: 'Docker', icon: 'docker', color: '#2496ED' },
];

const toolsTechs: TechItem[] = [
  { name: 'Git', icon: 'git', color: '#F05032' },
  { name: 'Vite', icon: 'vite', color: '#646CFF' },
  { name: 'Webpack', icon: 'webpack', color: '#8DD6F9' },
  { name: 'ESLint', icon: 'eslint', color: '#4B32C3' },
  { name: 'Prettier', icon: 'prettier', color: '#F7B93E' },
  { name: 'Jest', icon: 'jest', color: '#C21325' },
  { name: 'Figma', icon: 'figma', color: '#F24E1E' },
  { name: 'GitHub Actions', icon: 'githubactions', color: '#2088FF' },
  { name: 'GitLab CI', icon: 'gitlab', color: '#FC6D26' },
  { name: 'Claude Code', icon: 'anthropic', color: '#D97757' },
  { name: 'Cursor IDE', color: '#00B4D8' },
  { name: 'Windsurf IDE', color: '#00C49A' },
  { name: 'Turborepo', icon: 'turborepo', color: '#FF1E56' },
  { name: 'Cloudflare', icon: 'cloudflare', color: '#F38020' },
  { name: 'Playwright', color: '#2EAD33' },
];

const allTechs = [...frontendTechs, ...backendTechs, ...toolsTechs];

const techCategories = [
  { label: t('about.frontend', lang), items: frontendTechs, id: 'ticker-1', delay: '1000ms' },
  { label: t('about.backend', lang), items: backendTechs, id: 'ticker-2', delay: '1100ms' },
  { label: t('about.tools', lang), items: toolsTechs, id: 'ticker-3', delay: '1200ms' },
];

// Tech lookup for project cards — maps stack names to icon/color
const techLookup: Record<string, TechItem> = {};
for (const tech of allTechs) {
  techLookup[tech.name] = tech;
}
// Project-specific techs not in the main lists
Object.assign(techLookup, {
  'React 19': { name: 'React 19', icon: 'react', color: '#61DAFB' },
  'React 18': { name: 'React 18', icon: 'react', color: '#61DAFB' },
  'PixiJS 8': { name: 'PixiJS 8', iconUrl: 'https://api.iconify.design/devicon-plain/pixijs.svg?color=%23E72264', color: '#E72264' },
  'Bun': { name: 'Bun', icon: 'bun', color: '#FBF0DF' },
  'Capacitor': { name: 'Capacitor', icon: 'capacitor', color: '#119EFF' },
  'Hono': { name: 'Hono', icon: 'hono', color: '#E36002' },
  'TanStack Router': { name: 'TanStack Router', icon: 'tanstack', color: '#FF4154' },
  'TanStack Query': { name: 'TanStack Query', icon: 'reactquery', color: '#FF4154' },
  'React Hook Form': { name: 'React Hook Form', icon: 'reacthookform', color: '#EC5990' },
  'Framer Motion': { name: 'Framer Motion', icon: 'framer', color: '#0055FF' },
  'Zustand': { name: 'Zustand', iconUrl: 'https://api.iconify.design/devicon-plain/zustand.svg?color=%23F56565', color: '#F56565' },
  'Stripe': { name: 'Stripe', icon: 'stripe', color: '#635BFF' },
} satisfies Record<string, TechItem>);

const contactLinks = [
  { label: t('contact.email', lang), href: 'mailto:contact@arturwitkowski.com', icon: 'mail' },
  { label: t('contact.linkedin', lang), href: 'https://linkedin.com/in/artur-witkowski', icon: 'linkedin' },
  { label: t('contact.github', lang), href: 'https://github.com/artur-witkowski', icon: 'github' },
];
---

<Layout lang={lang}>
  <Nav lang={lang} />

  <!-- Aurora background -->
  <div id="aurora-bg" aria-hidden="true">
    <div class="aurora-blob aurora-blob-1"></div>
    <div class="aurora-blob aurora-blob-2"></div>
    <div class="aurora-blob aurora-blob-3"></div>
  </div>

  <main class="
    relative z-10
    px-3 py-3
    lg:px-5 lg:py-4
    lg:min-h-screen
    max-w-[1400px] mx-auto
    lg:flex lg:flex-col lg:gap-5
  ">

    {/* ===== TOP ROW: HERO + ABOUT ===== */}
    <div class="lg:grid lg:grid-cols-[2fr_3fr] lg:gap-5">

    {/* ===== HERO CARD ===== */}
    <section
      class="card-animate glass rounded-2xl p-6 lg:p-7
        flex flex-col justify-end relative overflow-hidden
        min-h-[55vh] lg:min-h-[420px] lg:min-w-0
        mb-3 lg:mb-0"
      style="animation-delay: 0ms"
    >
      {/* Profile photo ghost background */}
      <div class="hero-photo-bg" aria-hidden="true">
        <img src="/profile.webp" alt="" width="400" height="400" loading="eager" fetchpriority="high" />
      </div>

      <p class="relative z-10 text-text-muted font-body text-sm mb-2 hero-animate" style="animation-delay: 150ms">
        {t('hero.greeting', lang)}
      </p>

      <h1 class="relative z-10 font-heading font-bold text-[2rem] md:text-4xl xl:text-[2.75rem] leading-[1.1] mb-3 text-text">
        {nameChars.map((char, i) => (
          <span
            class={`split-char ${char === ' ' ? '' : ''}`}
            style={`--i: ${i}; --base-delay: 350ms`}
          >
            {char === ' ' ? '\u00A0' : char}
          </span>
        ))}
      </h1>

      <p class="relative z-10 font-body text-text-muted text-sm lg:text-[0.9rem] max-w-sm mb-5 leading-relaxed hero-animate" style="animation-delay: 1050ms">
        {t('hero.tagline', lang)}
      </p>

      <div class="relative z-10 flex items-center gap-2 flex-wrap hero-animate" style="animation-delay: 1200ms">
        <a href="https://github.com/artur-witkowski" target="_blank" rel="noopener noreferrer"
          class="social-icon inline-flex items-center gap-1.5 px-2.5 py-1.5 rounded-xl border border-border bg-surface/30 text-text-muted hover:text-accent cursor-pointer text-[11px] font-mono" aria-label="GitHub Personal">
          <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
            <path d="M9 18c-4.51 2-5-2-7-2" />
          </svg>
          personal
        </a>
        <a href="https://github.com/arturwitkowski-ps" target="_blank" rel="noopener noreferrer"
          class="social-icon inline-flex items-center gap-1.5 px-2.5 py-1.5 rounded-xl border border-border bg-surface/30 text-text-muted hover:text-accent cursor-pointer text-[11px] font-mono" aria-label="GitHub Work">
          <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
            <path d="M9 18c-4.51 2-5-2-7-2" />
          </svg>
          work
        </a>
        <a href="https://linkedin.com/in/artur-witkowski" target="_blank" rel="noopener noreferrer"
          class="social-icon p-2.5 rounded-xl border border-border bg-surface/30 text-text-muted hover:text-accent cursor-pointer" aria-label="LinkedIn">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
            <rect width="4" height="12" x="2" y="9" /><circle cx="4" cy="4" r="2" />
          </svg>
        </a>
        <a href="mailto:contact@arturwitkowski.com"
          class="social-icon p-2.5 rounded-xl border border-border bg-surface/30 text-text-muted hover:text-accent cursor-pointer" aria-label="Email">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="20" height="16" x="2" y="4" rx="2" />
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
          </svg>
        </a>
      </div>

      <p class="relative z-10 text-text-muted/70 text-[11px] font-mono mt-4 hero-animate" style="animation-delay: 1350ms">
        contact@arturwitkowski.com
      </p>
    </section>

    {/* ===== ABOUT CARD ===== */}
    <section
      class="card-animate glass rounded-2xl p-6 lg:p-7
        flex flex-col justify-center
        mb-3 lg:mb-0 lg:min-w-0"
      style="animation-delay: 150ms"
    >
      <h2 class="relative inline-block section-label text-accent font-body font-medium text-xs uppercase tracking-[1.5px] mb-3">
        {aboutLabelChars.map((char, i) => (
          <span
            class="split-char"
            style={`--i: ${i}; --base-delay: 500ms`}
          >
            {char === ' ' ? '\u00A0' : char}
          </span>
        ))}
      </h2>

      <p class="font-body text-text text-sm lg:text-[0.9rem] max-w-2xl leading-relaxed mb-5">
        {t('about.description', lang)}
      </p>

      <!-- Toggle -->
      <div class="flex items-center justify-end mb-2 hero-animate" style="animation-delay: 950ms">
        <button id="ticker-toggle" class="flex items-center gap-2 text-[10px] font-mono text-text-muted/50 hover:text-text-muted transition-colors cursor-pointer">
          <span id="toggle-track" class="relative w-7 h-3.5 rounded-full bg-border transition-colors duration-200">
            <span id="toggle-dot" class="absolute top-[2px] left-[2px] w-2.5 h-2.5 rounded-full bg-text-muted/60 transition-all duration-200"></span>
          </span>
          <span id="toggle-label">animation off</span>
        </button>
      </div>

      <!-- Tech categories — ticker + static in one container -->
      <div id="tech-container">
        {techCategories.map((cat, ci) => (
          <div class={`tech-category ${ci < 2 ? 'mb-2' : ''}`}>
            <p class="text-[10px] font-mono text-text-muted/40 uppercase tracking-wider mb-1.5 hero-animate" style={`animation-delay: ${cat.delay}`}>{cat.label}</p>

            {/* Animated ticker */}
            <div class="tech-ticker ticker-view hero-animate" style={`animation-delay: ${cat.delay}`}>
              <div class="tech-ticker__track" id={cat.id}>
                {[0, 1].map((copy) => (
                  <div class="tech-ticker__list" aria-hidden={copy > 0 ? 'true' : undefined}>
                    {cat.items.map((tech) => (
                      <span class="tech-ticker__item" style={`--card-color: ${tech.color || '#06b6d4'}`}>
                        {techIconSrc(tech) && <img src={techIconSrc(tech)} alt="" class="tech-ticker__icon" width="14" height="14" loading="lazy" onerror="this.style.display='none'" />}
                        {tech.name}
                      </span>
                    ))}
                  </div>
                ))}
              </div>
            </div>

            {/* Static wrapped tags (hidden by default) */}
            <div class="chroma-tags static-view" style="display: none">
              {cat.items.map((tech, ti) => (
                <span class="chroma-tags__item tech-tag-pop" style={`--card-color: ${tech.color || '#06b6d4'}; --pop-i: ${ti}`}>
                  {techIconSrc(tech) && <img src={techIconSrc(tech)} alt="" class="chroma-tags__icon" width="14" height="14" loading="lazy" onerror="this.style.display='none'" />}
                  {tech.name}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    </div>{/* close top row grid */}

    {/* ===== PROJECTS CAROUSEL ===== */}
    <section
      class="card-animate flex flex-col mb-3 lg:mb-0 min-h-0"
      style="animation-delay: 300ms"
    >
      <div class="flex items-center justify-between mb-2.5 px-1">
        <h2 class="relative inline-block section-label text-accent font-body font-medium text-xs uppercase tracking-[1.5px]">
          {projectsLabelChars.map((char, i) => (
            <span
              class="split-char"
              style={`--i: ${i}; --base-delay: 700ms`}
            >
              {char === ' ' ? '\u00A0' : char}
            </span>
          ))}
        </h2>
        <div class="flex items-center gap-2 lg:hidden">
          <div class="flex items-center gap-1.5" id="carousel-dots">
            {projects.map((_, i) => (
              <button
                class={`carousel-dot ${i === 0 ? 'active' : ''}`}
                data-index={i}
                aria-label={`Project ${i + 1}`}
              />
            ))}
          </div>
          <button id="carousel-prev" class="p-1.5 rounded-lg border border-border text-text-muted hover:text-accent hover:border-accent/30 transition-all duration-200 cursor-pointer" aria-label="Previous">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          </button>
          <button id="carousel-next" class="p-1.5 rounded-lg border border-border text-text-muted hover:text-accent hover:border-accent/30 transition-all duration-200 cursor-pointer" aria-label="Next">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </button>
        </div>
      </div>

      <div class="carousel-track flex-1" id="carousel-track">
        {projects.map((project) => {
          const desc = project.description[lang];
          const typeLabel = project.type === 'solo' ? t('projects.solo', lang) : t('projects.team', lang);
          return (
            <div class="carousel-card glass rounded-2xl p-5 lg:p-5 flex flex-col">
              {/* Browser frame screenshot */}
              {project.image && (
                <div class="browser-frame mb-3 rounded-lg overflow-hidden border border-border/50">
                  <div class="browser-frame__bar flex items-center gap-1.5 px-3 py-1.5 bg-surface/60">
                    <span class="w-2 h-2 rounded-full bg-text-muted/20"></span>
                    <span class="w-2 h-2 rounded-full bg-text-muted/20"></span>
                    <span class="w-2 h-2 rounded-full bg-text-muted/20"></span>
                    <span class="flex-1 mx-2 h-4 rounded bg-surface-hover/50 flex items-center px-2">
                      <span class="text-[8px] font-mono text-text-muted/60 truncate" aria-hidden="true">{project.url}</span>
                    </span>
                  </div>
                  <img
                    src={project.image}
                    alt={project.name}
                    width="600"
                    height="375"
                    class="w-full aspect-[16/9] object-cover object-top"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
              )}

              <div class="flex items-start justify-between gap-2 mb-2">
                <h3 class="font-heading font-semibold text-base lg:text-lg text-text leading-snug">
                  {project.name}
                </h3>
                <span class={`shrink-0 text-[9px] font-mono px-1.5 py-0.5 rounded-full whitespace-nowrap ${project.type === 'solo' ? 'text-emerald-400 bg-emerald-400/10 border border-emerald-400/20' : 'text-violet-400 bg-violet-400/10 border border-violet-400/20'}`}>
                  {typeLabel}
                </span>
              </div>

              <p class="font-body text-text-muted text-xs leading-relaxed mb-3 flex-1">
                {desc}
              </p>

              <div class="chroma-tags mb-3">
                {project.stack.map((techName) => {
                  const tech = techLookup[techName];
                  const color = tech?.color || '#06b6d4';
                  const src = tech ? techIconSrc(tech) : undefined;
                  return (
                    <span class="chroma-tags__item" style={`--card-color: ${color}`}>
                      {src && <img src={src} alt="" class="chroma-tags__icon" width="14" height="14" loading="lazy" onerror="this.style.display='none'" />}
                      {techName}
                    </span>
                  );
                })}
              </div>

              <a
                href={project.url}
                target="_blank"
                rel="noopener noreferrer"
                class="glow-link inline-flex items-center gap-1 text-xs text-primary hover:text-accent font-body font-medium cursor-pointer group w-fit mt-auto"
              >
                {t('projects.visit', lang)}
                <svg class="w-3 h-3 transition-transform duration-200 group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
                </svg>
              </a>
            </div>
          );
        })}
      </div>
    </section>

    {/* ===== FOOTER BAR ===== */}
    <section
      class="card-animate glass rounded-2xl px-5 py-2.5
        lg:mt-auto
        flex flex-col sm:flex-row items-center justify-between gap-2"
      style="animation-delay: 450ms"
    >
      <div class="flex flex-col sm:flex-row items-center gap-2 sm:flex-wrap justify-center sm:justify-start">
        <p class="text-text-muted font-body text-xs">{t('contact.cta', lang)}</p>
        <div class="flex items-center gap-2">
        {contactLinks.map((link) => (
          <a
            href={link.href}
            target={link.href.startsWith('mailto:') ? undefined : '_blank'}
            rel={link.href.startsWith('mailto:') ? undefined : 'noopener noreferrer'}
            class="social-icon flex items-center gap-1.5 px-2.5 py-1 rounded-lg border border-border bg-surface/30 text-text-muted hover:text-accent text-[11px] font-medium cursor-pointer"
          >
            {link.icon === 'mail' && (
              <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect width="20" height="16" x="2" y="4" rx="2" /><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
              </svg>
            )}
            {link.icon === 'linkedin' && (
              <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
                <rect width="4" height="12" x="2" y="9" /><circle cx="4" cy="4" r="2" />
              </svg>
            )}
            {link.icon === 'github' && (
              <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
                <path d="M9 18c-4.51 2-5-2-7-2" />
              </svg>
            )}
            {link.label}
          </a>
        ))}
        </div>
      </div>
      <span class="text-text-muted text-xs font-body">&copy; 2026 Artur Witkowski</span>
    </section>

  </main>
</Layout>

<script is:inline>
(function () {
  // ===== CAROUSEL =====
  var track = document.getElementById('carousel-track');
  var dots = document.querySelectorAll('.carousel-dot');
  var prevBtn = document.getElementById('carousel-prev');
  var nextBtn = document.getElementById('carousel-next');

  if (track && dots.length) {
    function getCardWidth() {
      var card = track.querySelector('.carousel-card');
      if (!card) return 300;
      return card.offsetWidth + 12;
    }

    function getCurrentIndex() {
      return Math.round(track.scrollLeft / getCardWidth());
    }

    function scrollToIndex(idx) {
      track.scrollTo({ left: idx * getCardWidth(), behavior: 'smooth' });
    }

    function updateDots() {
      var idx = getCurrentIndex();
      dots.forEach(function (d, i) {
        d.classList.toggle('active', i === idx);
      });
    }

    track.addEventListener('scroll', updateDots);

    dots.forEach(function (dot) {
      dot.addEventListener('click', function () {
        scrollToIndex(parseInt(dot.getAttribute('data-index')));
      });
    });

    if (prevBtn) prevBtn.addEventListener('click', function () {
      var idx = getCurrentIndex();
      if (idx > 0) scrollToIndex(idx - 1);
    });

    if (nextBtn) nextBtn.addEventListener('click', function () {
      var idx = getCurrentIndex();
      var maxIdx = dots.length - 1;
      if (idx < maxIdx) scrollToIndex(idx + 1);
    });
  }

  // ===== TICKER TOGGLE =====
  var tickerToggle = document.getElementById('ticker-toggle');
  var toggleDot = document.getElementById('toggle-dot');
  var toggleLabel = document.getElementById('toggle-label');
  var toggleTrack = document.getElementById('toggle-track');
  var categories = document.querySelectorAll('.tech-category');
  var isAnimated = true;
  var isTransitioning = false;

  function swap(toStatic) {
    if (isTransitioning) return;
    isTransitioning = true;

    var FADE = 180;

    categories.forEach(function (cat) {
      var ticker = cat.querySelector('.ticker-view');
      var statics = cat.querySelector('.static-view');
      var outgoing = toStatic ? ticker : statics;
      var incoming = toStatic ? statics : ticker;

      // 1. Snapshot start height
      var startH = cat.offsetHeight;
      cat.style.height = startH + 'px';

      // 2. Fade out outgoing
      outgoing.style.transition = 'opacity ' + FADE + 'ms ease';
      outgoing.style.opacity = '0';

      setTimeout(function () {
        // 3. Hide outgoing
        outgoing.style.display = 'none';
        outgoing.style.transition = '';
        outgoing.style.opacity = '';

        // Reset pop-active when hiding static
        if (!toStatic) {
          statics.querySelectorAll('.tech-tag-pop').forEach(function (t) {
            t.classList.remove('pop-active');
          });
        }

        // 4. Show incoming (transparent, for measurement)
        incoming.style.display = '';
        incoming.style.opacity = '0';

        // 5. Measure target: set height auto without transition, read, snap back
        cat.style.transition = 'none';
        cat.style.height = 'auto';
        var targetH = cat.offsetHeight;
        cat.style.height = startH + 'px';
        void cat.offsetHeight; // force reflow

        // 6. Animate height
        cat.style.transition = '';
        cat.style.height = targetH + 'px';

        // 7. Fade in incoming content
        requestAnimationFrame(function () {
          if (toStatic) {
            statics.querySelectorAll('.tech-tag-pop').forEach(function (tag) {
              tag.style.animation = 'none';
              void tag.offsetHeight;
              tag.style.animation = '';
              tag.classList.add('pop-active');
            });
          } else {
            incoming.style.transition = 'opacity 0.25s ease';
            incoming.style.opacity = '1';
          }
        });

        // 8. Clean up after height transition completes
        setTimeout(function () {
          cat.style.height = '';
          cat.style.transition = '';
          incoming.style.transition = '';
          incoming.style.opacity = '';
          isTransitioning = false;
        }, 550);
      }, FADE);
    });
  }

  if (tickerToggle) {
    tickerToggle.addEventListener('click', function () {
      isAnimated = !isAnimated;
      swap(!isAnimated);
      toggleDot.style.transform = isAnimated ? '' : 'translateX(12px)';
      toggleTrack.style.background = isAnimated ? '' : 'rgba(6, 182, 212, 0.3)';
      toggleLabel.textContent = isAnimated ? 'animation off' : 'animation on';
    });
  }

  // ===== TECH TICKERS =====
  var tickerAnimIds = {};
  function animateTicker(trackId, speed) {
    var tickerTrack = document.getElementById(trackId);
    if (!tickerTrack) return;
    var firstList = tickerTrack.querySelector('.tech-ticker__list');
    if (!firstList) return;

    var listWidth = firstList.offsetWidth;
    if (listWidth <= 0) return;

    var offset = speed > 0 ? 0 : listWidth;
    var lastTime = performance.now();

    function tick(now) {
      var dt = Math.min((now - lastTime) / 1000, 0.1);
      lastTime = now;
      offset += speed * dt;
      while (offset >= listWidth) offset -= listWidth;
      while (offset < 0) offset += listWidth;
      tickerTrack.style.transform = 'translate3d(' + (-offset) + 'px, 0, 0)';
      tickerAnimIds[trackId] = requestAnimationFrame(tick);
    }
    tickerAnimIds[trackId] = requestAnimationFrame(tick);
  }

  // After entrance animations finish, strip hero-animate so toggle doesn't replay them
  setTimeout(function () {
    document.querySelectorAll('#tech-container .hero-animate').forEach(function (el) {
      el.classList.remove('hero-animate');
    });
  }, 2000);

  // Start tickers — 3 rows, alternating directions
  setTimeout(function () {
    animateTicker('ticker-1', 30);
    animateTicker('ticker-2', -25);
    animateTicker('ticker-3', 22);
  }, 200);

})();
</script>
