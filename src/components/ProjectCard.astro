---
import type { Lang } from '@/i18n/index';
import { t } from '@/i18n/index';
import type { Project } from '@/data/projects';

interface Props {
  project: Project;
  lang: Lang;
  index: number;
}

const { project, lang, index } = Astro.props;
const description = project.description[lang];
const typeLabel = project.type === 'solo' ? t('projects.solo', lang) : t('projects.team', lang);
---

<div class="reveal card-glow rounded-xl border border-border bg-surface/60 backdrop-blur-sm overflow-hidden" data-delay={String(index * 120)}>
  <div class="flex flex-col md:flex-row">
    <!-- Screenshot placeholder -->
    <div class="md:w-1/3 lg:w-[28%] aspect-video md:aspect-auto relative overflow-hidden shrink-0">
      <div class="absolute inset-0 bg-gradient-to-br from-primary/8 via-surface to-blue/8"></div>
      <div class="absolute inset-0 flex items-center justify-center">
        <span class="font-heading font-semibold text-xl gradient-text-static opacity-25">{project.name}</span>
      </div>
    </div>

    <!-- Content -->
    <div class="p-5 md:p-5 lg:p-4 lg:py-3 flex flex-col justify-center">
      <div class="flex items-start justify-between gap-3 mb-2">
        <h3 class="font-heading font-semibold text-lg md:text-xl text-text">
          {project.name}
        </h3>
        <span class="shrink-0 text-[10px] font-mono text-primary px-2 py-0.5 rounded-full bg-primary/10 border border-primary/20">
          {typeLabel}
        </span>
      </div>

      <p class="font-body text-text-muted text-sm leading-relaxed mb-3">
        {description}
      </p>

      <!-- Tech tags -->
      <div class="flex flex-wrap gap-1.5 mb-3">
        {project.stack.map((tech) => (
          <span class="tech-tag px-2 py-0.5 rounded border border-border text-[11px] font-mono text-text-muted">
            {tech}
          </span>
        ))}
      </div>

      <!-- Visit link -->
      <a
        href={project.url}
        target="_blank"
        rel="noopener noreferrer"
        class="glow-link inline-flex items-center gap-1.5 text-sm text-primary hover:text-accent font-body font-medium cursor-pointer group w-fit"
      >
        {t('projects.visit', lang)}
        <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover:translate-x-1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14" />
          <path d="m12 5 7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</div>
