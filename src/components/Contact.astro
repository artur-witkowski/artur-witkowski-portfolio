---
import type { Lang } from '@/i18n/index';
import { t } from '@/i18n/index';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const links = [
  {
    label: t('contact.email', lang),
    href: 'mailto:contact@arturwitkowski.com',
    icon: 'mail',
  },
  {
    label: t('contact.linkedin', lang),
    href: 'https://linkedin.com/in/artur-witkowski',
    icon: 'linkedin',
  },
  {
    label: t('contact.github', lang),
    href: 'https://github.com/artur-witkowski',
    icon: 'github',
  },
];
---

<div class="gradient-divider" aria-hidden="true"></div>

<section id="contact" class="py-16 md:py-20 lg:py-14 px-6 relative">
  <div class="max-w-4xl mx-auto text-center relative z-10">
    <p class="reveal section-label text-accent font-body font-medium text-sm uppercase tracking-[1.5px] mb-3 mx-auto w-fit">
      {t('contact.label', lang)}
    </p>
    <p class="reveal font-body text-text text-lg md:text-xl mb-8 lg:mb-6" data-delay="100">
      {t('contact.cta', lang)}
    </p>

    <div class="reveal flex flex-col sm:flex-row items-center justify-center gap-3" data-delay="200">
      {links.map((link) => (
        <a
          href={link.href}
          target={link.href.startsWith('mailto:') ? undefined : '_blank'}
          rel={link.href.startsWith('mailto:') ? undefined : 'noopener noreferrer'}
          class="contact-card flex items-center gap-2.5 px-6 py-4 rounded-xl border border-border bg-surface/60 backdrop-blur-sm text-text-muted hover:text-accent cursor-pointer w-full sm:w-auto justify-center"
        >
          {link.icon === 'mail' && (
            <svg class="w-4.5 h-4.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="16" x="2" y="4" rx="2" />
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
            </svg>
          )}
          {link.icon === 'linkedin' && (
            <svg class="w-4.5 h-4.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
              <rect width="4" height="12" x="2" y="9" />
              <circle cx="4" cy="4" r="2" />
            </svg>
          )}
          {link.icon === 'github' && (
            <svg class="w-4.5 h-4.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
              <path d="M9 18c-4.51 2-5-2-7-2" />
            </svg>
          )}
          <span class="font-body font-medium">{link.label}</span>
        </a>
      ))}
    </div>
  </div>
</section>
