---
import type { Lang } from '@/i18n/index';
import { t } from '@/i18n/index';
import { projects } from '@/data/projects';
import ProjectCard from './ProjectCard.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<div class="gradient-divider" aria-hidden="true"></div>

<section id="projects" class="py-16 md:py-20 lg:py-14 px-6">
  <div class="max-w-4xl mx-auto">
    <p class="reveal section-label text-accent font-body font-medium text-sm uppercase tracking-[1.5px] mb-8">
      {t('projects.label', lang)}
    </p>

    <div class="space-y-5 lg:space-y-4">
      {projects.map((project, i) => (
        <ProjectCard project={project} lang={lang} index={i} />
      ))}
    </div>
  </div>
</section>
