---
import type { Lang } from '@/i18n/index';
import { t } from '@/i18n/index';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const techGroups = [
  {
    label: t('about.frontend', lang),
    tags: ['React', 'Next.js', 'TypeScript', 'Tailwind CSS', 'React Native'],
  },
  {
    label: t('about.backend', lang),
    tags: ['Node.js', 'PostgreSQL', 'Prisma', 'Drizzle ORM'],
  },
  {
    label: t('about.tools', lang),
    tags: ['Docker', 'Git', 'GitHub Actions', 'Figma', 'Claude Code'],
  },
];
---

<div class="gradient-divider" aria-hidden="true"></div>

<section id="about" class="py-16 md:py-20 lg:py-14 px-6">
  <div class="max-w-4xl mx-auto">
    <p class="reveal section-label text-accent font-body font-medium text-sm uppercase tracking-[1.5px] mb-5">
      {t('about.label', lang)}
    </p>
    <p class="reveal font-body text-text text-lg md:text-xl max-w-2xl leading-relaxed mb-8 lg:mb-6" data-delay="100">
      {t('about.description', lang)}
    </p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {techGroups.map((group, gi) => (
        <div class="reveal rounded-xl border border-border bg-surface/50 p-5" data-delay={String(150 + gi * 80)}>
          <p class="text-xs font-mono font-medium text-primary uppercase tracking-wider mb-3">
            {group.label}
          </p>
          <div class="flex flex-wrap gap-1.5">
            {group.tags.map((tag) => (
              <span class="tech-tag inline-flex items-center px-2.5 py-1 rounded-md border border-border text-xs font-mono text-text-muted cursor-default">
                {tag}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
