---
// Root page — instant client-side redirect to /pl/ or /en/ based on browser language
---

<html>
  <head>
    <meta charset="utf-8" />
    <script is:inline>
      var s = localStorage.getItem('lang');
      var l = s || (navigator.language.startsWith('pl') ? 'pl' : 'en');
      window.location.replace('/' + l + '/');
    </script>
  </head>
  <body style="display:none"></body>
</html>
